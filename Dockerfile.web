FROM node:22-alpine AS base
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable

# ── Stage 1: install deps ────────────────────────────────────────────────────
FROM base AS deps

WORKDIR /repo
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY apps/web/package.json apps/web/
COPY packages/ui/package.json packages/ui/
COPY packages/typescript-config/package.json packages/typescript-config/
COPY packages/eslint-config/package.json packages/eslint-config/

RUN --mount=type=cache,id=pnpm,target=/pnpm/store \
    pnpm install --frozen-lockfile

# ── Stage 2: build ──────────────────────────────────────────────────────────
FROM base AS builder

WORKDIR /repo
COPY --from=deps /repo/node_modules ./node_modules
COPY --from=deps /repo/apps/web/node_modules apps/web/node_modules
COPY --from=deps /repo/packages/ui/node_modules packages/ui/node_modules
COPY pnpm-workspace.yaml package.json ./
COPY apps/web/ apps/web/
COPY packages/ packages/

# ARCHIMATE_API_URL is baked into the rewrite rules at build time
ARG ARCHIMATE_API_URL=http://api:8000
ENV ARCHIMATE_API_URL=${ARCHIMATE_API_URL}

WORKDIR /repo/apps/web
RUN pnpm build

# ── Stage 3: runner ─────────────────────────────────────────────────────────
FROM node:22-alpine AS runner

ENV NODE_ENV=production
WORKDIR /app

# Standalone output includes all server-side code
COPY --from=builder /repo/apps/web/.next/standalone ./
# Static assets and public files must be copied separately
COPY --from=builder /repo/apps/web/.next/static apps/web/.next/static
COPY --from=builder /repo/apps/web/public apps/web/public

EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

CMD ["node", "apps/web/server.js"]
