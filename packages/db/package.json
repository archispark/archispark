{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && cp -r drizzle-pg dist/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "seed:demo-users": "tsx scripts/seed-demo-users.ts",
    "setup:realm": "tsx scripts/setup-realm.ts",
    "migrate:prod": "tsx scripts/migrate-prod.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@workspace/auth": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.11.11",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "@workspace/typescript-config": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
