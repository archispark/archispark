{
  "$schema": "https://v2-9-16.turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": ["ARCHIMATE_API_URL", "NEXT_PUBLIC_MCP_SERVER_URL"]
    },
    "test": {
      "cache": false
    },
    "test:coverage": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "DATABASE_URL",
        "REDIS_URL",
        "BETTER_AUTH_SECRET",
        "WEB_URL",
        "TRUSTED_ORIGINS",
        "SEED_ADMIN_PASSWORD",
        "SEED_USER_PASSWORD",
        "ARCHIMATE_API_URL",
        "NODE_OPTIONS",
        "PORT",
        "HOST"
      ]
    }
  }
}
