# ─────────────────────────────────────────────────────────────────────────────
#  ArchiSpark — Variables d'environnement
#  Copier ce fichier : cp .env.example .env
#  Ne jamais commiter .env dans git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Domaine ────────────────────────────────────────────────────────────────
# URL publique de l'application (utilisée par Better Auth pour les cookies)
ARCHISPARK_URL=http://localhost

# ── Base de données ─────────────────────────────────────────────────────────
# Mot de passe PostgreSQL — utiliser un mot de passe fort en production
DB_PASSWORD=changeme

# ── Authentification ────────────────────────────────────────────────────────
# Clé secrète Better Auth — générer avec : openssl rand -hex 32
BETTER_AUTH_SECRET=changeme-generate-with-openssl-rand-hex-32

# ── Utilisateurs initiaux ───────────────────────────────────────────────────
# Créés au premier démarrage si inexistants.
# Laisser vide pour désactiver le seed.
SEED_ADMIN_PASSWORD=
SEED_USER_PASSWORD=

# ── TLS Let's Encrypt (optionnel) ────────────────────────────────────────────
# Décommenter et renseigner pour activer les certificats automatiques.
# Voir les instructions dans traefik.yml.
#ACME_EMAIL=votre@email.com
