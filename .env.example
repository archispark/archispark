# ─────────────────────────────────────────────────────────────────────────────
#  ArchiSpark Docker — Variables d'environnement
#  Copier ce fichier : cp .env.example .env.dev (ou .env.prod) — ou `make env`.
#  Ne jamais commiter .env.dev / .env.prod dans git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Image de base ─────────────────────────────────────────────────────────────
# alpine      → node:22-alpine      (images légères, musl libc)
# trixie-slim → node:22-trixie-slim (Debian Testing, glibc)
ARCHISPARK_OS=alpine

# ── Version des images ────────────────────────────────────────────────────────
# Tag Docker Hub utilisé par docker-compose.yml (ex: latest, 0.5.2)
ARCHISPARK_VERSION=latest

# ── URL publique ────────────────────────────────────────────────────────────
ARCHISPARK_URL=http://localhost

# ── Base de données ─────────────────────────────────────────────────────────
DB_PASSWORD=archispark

# Connexion poolée utilisée par les apps (control-api, tenant-api, mcp-server).
# En local : Postgres exposé sur localhost:5432 par make dev-infra.
# Sur Vercel : Neon injecte automatiquement DATABASE_URL (pooled) via Marketplace.
DATABASE_URL=postgresql://archispark:${DB_PASSWORD}@localhost:5432/archispark

# Connexion directe (non-poolée) — migrations manuelles et seed depuis CI/CD.
# Sur Vercel / Neon : DATABASE_URL_UNPOOLED (auto-injecté par Neon Marketplace).
# En local : même URL que DATABASE_URL (pg.Pool gère lui-même le pooling).
#DATABASE_URL_UNPOOLED=postgresql://archispark:${DB_PASSWORD}@localhost:5432/archispark

# Base de données partagée pour les tenants sans Neon dédié (isolation physique
# de la base control). Créée automatiquement par le script Docker initdb.
# Utilisée par tenant-api et mcp-server en mode repli.
TENANT_DATABASE_URL=postgresql://archispark:${DB_PASSWORD}@localhost:5432/archispark_tenant

# Connexion directe tenant (non-poolée) — seed demo depuis CI/CD.
# Sur Vercel / Neon : renommer DATABASE_URL_UNPOOLED du 2e projet Neon.
#TENANT_DATABASE_URL_UNPOOLED=postgresql://archispark:${DB_PASSWORD}@localhost:5432/archispark_tenant

# ── Keycloak (Phasetwo) — local dev ─────────────────────────────────────────
# Bootstrap superuser pour la console d'administration Keycloak (dev only).
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Utilisé par packages/auth (control-api) pour vérifier les access tokens via JWKS.
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=archispark

# Client IDs publics (utilisés par web/admin-web à partir de l'étape 3).
KEYCLOAK_CLIENT_ID_WEB=archispark-web
KEYCLOAK_CLIENT_ID_ADMIN_WEB=archispark-admin-web

# Client confidentiel / service account de control-api (Admin API, étape 5+).
KEYCLOAK_ADMIN_CLIENT_ID=archispark-control-api
KEYCLOAK_ADMIN_CLIENT_SECRET=archispark-control-api-secret

# ── Inter-service control-api ↔ tenant-api ──────────────────────────────────
# URL du tenant-api (control-api proxie les requêtes workspace/element vers lui)
TENANT_API_URL=http://localhost:3002

# Secret partagé pour signer/vérifier le JWT inter-service de courte durée
# (control-api signe, tenant-api vérifie). Générer avec : openssl rand -hex 32
TENANT_JWT_SECRET=changeme-generate-with-openssl-rand-hex-32

# Clé de déchiffrement des chaînes de connexion par-tenant (Neon ou Postgres
# local, tenant-api, mcp-server). Générer avec : openssl rand -hex 32
TENANT_DB_ENCRYPTION_KEY=changeme-generate-with-openssl-rand-hex-32

# Mot de passe du rôle Postgres restreint utilisé par tenant-api en mode repli
# (accès SELECT/INSERT/UPDATE/DELETE sur les tables schema.tenant.ts uniquement).
# control-api crée/met à jour ce rôle au démarrage (ensureTenantRole).
# Générer avec : openssl rand -hex 32
TENANT_DB_PASSWORD=changeme-generate-with-openssl-rand-hex-32

# ── MCP Server ──────────────────────────────────────────────────────────────
# URL publique du serveur MCP (affichée dans la configuration Claude Code).
NEXT_PUBLIC_MCP_SERVER_URL=https://archispark-mcp-server.vercel.app/mcp/
# Bearer token pour l'authentification des clients MCP (Claude Code, agents IA).
# Générer depuis le menu utilisateur → Token MCP, puis coller ici.
# Laisser vide pour désactiver l'authentification MCP (non recommandé en prod).
MCP_AUTH_TOKEN=

# ── TLS Let's Encrypt — Traefik uniquement ────────────────────────────────
#ACME_EMAIL=votre@email.com
