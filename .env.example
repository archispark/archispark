# ─────────────────────────────────────────────────────────────────────────────
#  ArchiSpark Docker — Variables d'environnement
#  Copier ce fichier : cp .env.example .env.dev (ou .env.prod) — ou `make env`.
#  Ne jamais commiter .env.dev / .env.prod dans git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Image de base ─────────────────────────────────────────────────────────────
# alpine      → node:22-alpine      (images légères, musl libc)
# trixie-slim → node:22-trixie-slim (Debian Testing, glibc)
ARCHISPARK_OS=alpine

# ── Version des images ────────────────────────────────────────────────────────
# Tag Docker Hub utilisé par docker-compose.yml (ex: latest, 0.5.2)
ARCHISPARK_VERSION=latest

# ── URL publique ────────────────────────────────────────────────────────────
# Utilisée par apps/api pour construire les liens d'invitation par e-mail
# (jamais reconstruite depuis l'en-tête Host, qui est contrôlable par
# l'appelant).
ARCHISPARK_URL=http://localhost

# ── Base de données ─────────────────────────────────────────────────────────
DB_PASSWORD=archispark

# Connexion poolée utilisée par les apps (api, mcp-server) — base unique
# partagée (auth/tokens et contenu ArchiMate).
# En local : Postgres exposé sur localhost:5432 par make dev-infra.
# Sur Vercel : Neon injecte automatiquement DATABASE_URL (pooled) via Marketplace.
DATABASE_URL=postgresql://archispark:${DB_PASSWORD}@localhost:5432/archispark

# Connexion directe (non-poolée) — migrations manuelles et seed depuis CI/CD.
# Sur Vercel / Neon : DATABASE_URL_UNPOOLED (auto-injecté par Neon Marketplace).
# En local : même URL que DATABASE_URL (pg.Pool gère lui-même le pooling).
#DATABASE_URL_UNPOOLED=postgresql://archispark:${DB_PASSWORD}@localhost:5432/archispark

# ── Keycloak — local dev ─────────────────────────────────────────────────────
# Bootstrap superuser pour la console d'administration Keycloak (dev only).
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Utilisé par packages/auth (api) pour vérifier les access tokens via JWKS.
# KEYCLOAK_URL est le même Keycloak partagé pour tous les déploiements ;
# KEYCLOAK_REALM varie par déploiement (un realm dédié par client — voir
# docs/deployment.md#onboarding-dun-nouveau-client-un-realm-keycloak-dédié).
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=archispark

# Client ID public (utilisé par web à partir de l'étape 3).
KEYCLOAK_CLIENT_ID_WEB=archispark-web

# Client confidentiel / service account de l'api (Admin API, étape 5+).
KEYCLOAK_ADMIN_CLIENT_ID=archispark-api
KEYCLOAK_ADMIN_CLIENT_SECRET=archispark-api-secret

# Auto-inscription Keycloak + invitations par e-mail (organisation.ts,
# apps/api/src/invitations-store.ts) — n'a d'effet que si explicitement
# définie (voir packages/db/scripts/setup-realm.ts). Le realm `archispark`
# de dev EST le realm mutualisé de référence, donc activée ici ; un realm
# dédié à un client ne doit PAS définir ces deux variables (config du realm
# inchangée par défaut — voir docs/deployment.md).
KEYCLOAK_SELF_REGISTRATION=true
KEYCLOAK_VERIFY_EMAIL=true

# ── Invitations par e-mail (SMTP) ───────────────────────────────────────────
# Utilisé à la fois par apps/api (e-mail "vous êtes invité", nodemailer) et
# par Keycloak lui-même (e-mail natif de vérification d'adresse après
# inscription — voir setup-realm.ts). Laisser SMTP_HOST vide désactive
# l'envoi (l'invitation reste créée mais sentAt=null, voir docs/architecture.md).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@archispark.local

# ── MCP Server ──────────────────────────────────────────────────────────────
# URL publique du serveur MCP (affichée dans la configuration Claude Code).
NEXT_PUBLIC_MCP_SERVER_URL=http://localhost:3001/mcp/
# Bearer token pour l'authentification des clients MCP (Claude Code, agents IA).
# Générer depuis le menu utilisateur → Token MCP, puis coller ici.
# Laisser vide pour désactiver l'authentification MCP (non recommandé en prod).
MCP_AUTH_TOKEN=

# ── TLS Let's Encrypt — Traefik uniquement ────────────────────────────────
#ACME_EMAIL=votre@email.com
