# ─────────────────────────────────────────────────────────────────────────────
#  ArchiSpark — Variables d'environnement
#  Copier ce fichier : cp .env.example .env
#  Ne jamais commiter .env dans git.
# ─────────────────────────────────────────────────────────────────────────────

# ── URL publique ────────────────────────────────────────────────────────────
# URL complète de l'application (Better Auth, cookies de session)
ARCHISPARK_URL=http://localhost

# Caddy uniquement : nom de domaine pour le TLS Let's Encrypt automatique
# localhost = HTTP uniquement ; un vrai domaine = HTTPS automatique
ARCHISPARK_HOST=localhost

# ── Base de données ─────────────────────────────────────────────────────────
# Requis avec docker-compose.postgres.yml
DB_PASSWORD=changeme

# ── Authentification ────────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
BETTER_AUTH_SECRET=changeme-generate-with-openssl-rand-hex-32

# ── Utilisateurs initiaux ───────────────────────────────────────────────────
# Créés au premier démarrage si inexistants. Laisser vide pour désactiver.
SEED_ADMIN_PASSWORD=
SEED_USER_PASSWORD=

# ── TLS Let's Encrypt — Traefik uniquement ────────────────────────────────
# Décommenter et configurer traefik.yml pour activer HTTPS
#ACME_EMAIL=votre@email.com
