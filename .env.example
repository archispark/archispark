# ─────────────────────────────────────────────────────────────────────────────
#  ArchiSpark Docker — Variables d'environnement
#  Copier ce fichier : cp .env.example .env
#  Ne jamais commiter .env dans git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Image de base ─────────────────────────────────────────────────────────────
# alpine      → node:22-alpine      (images légères, musl libc)
# trixie-slim → node:22-trixie-slim (Debian Testing, glibc)
ARCHISPARK_OS=alpine

# ── Version des images ────────────────────────────────────────────────────────
# Tag Docker Hub utilisé par docker-compose.yml (ex: latest, 0.5.2)
ARCHISPARK_VERSION=latest

# ── URL publique ────────────────────────────────────────────────────────────
ARCHISPARK_URL=http://localhost

# ── Base de données ─────────────────────────────────────────────────────────
DB_PASSWORD=archispark

# Connexion utilisée par `make dev` (pnpm dev en local, Postgres exposé sur
# localhost:5432 par dev-infra). DATABASE_URL est obligatoire — pas de valeur
# par défaut dans packages/db/src/connection.ts.
DATABASE_URL=postgresql://archispark:${DB_PASSWORD}@localhost:5432/archispark

# ── Redis (requis) ──────────────────────────────────────────────────────────
# Redis est obligatoire pour le stockage de sessions et le rate-limiting.
# Laisser vide pour désactiver le mot de passe Redis (non recommandé en prod).
REDIS_PASSWORD=
# Si REDIS_PASSWORD est défini ci-dessus, mettre à jour REDIS_URL en conséquence :
# REDIS_URL=redis://:monmotdepasse@redis:6379
REDIS_URL=redis://redis:6379

# ── Authentification ────────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
BETTER_AUTH_SECRET=changeme-generate-with-openssl-rand-hex-32

# Origines supplémentaires autorisées (CSRF) — séparées par des virgules
# Nécessaire si l'app est accessible depuis plusieurs domaines ou IPs LAN
# Exemple : TRUSTED_ORIGINS=http://192.168.1.10:8000,https://autre.domaine.com
TRUSTED_ORIGINS=

# ── Inter-service control-api ↔ tenant-api ──────────────────────────────────
# Secret partagé pour signer/vérifier le JWT inter-service de courte durée
# (control-api signe, tenant-api vérifie). Générer avec : openssl rand -hex 32
TENANT_JWT_SECRET=changeme-generate-with-openssl-rand-hex-32

# Clé de déchiffrement des chaînes de connexion Neon par-tenant (tenant-api,
# mcp-server). Générer avec : openssl rand -hex 32
TENANT_DB_ENCRYPTION_KEY=changeme-generate-with-openssl-rand-hex-32

# Mot de passe du rôle Postgres restreint utilisé par tenant-api en mode repli
# (accès SELECT/INSERT/UPDATE/DELETE sur les tables schema.tenant.ts uniquement).
# control-api crée/met à jour ce rôle au démarrage (ensureTenantRole).
# Générer avec : openssl rand -hex 32
TENANT_DB_PASSWORD=changeme-generate-with-openssl-rand-hex-32

# ── MCP Server ──────────────────────────────────────────────────────────────
# URL publique du serveur MCP (affichée dans la configuration Claude Code).
NEXT_PUBLIC_MCP_SERVER_URL=https://archispark-mcp-server.vercel.app/mcp/
# Bearer token pour l'authentification des clients MCP (Claude Code, agents IA).
# Générer depuis le menu utilisateur → Token MCP, puis coller ici.
# Laisser vide pour désactiver l'authentification MCP (non recommandé en prod).
MCP_AUTH_TOKEN=

# ── Utilisateurs initiaux ───────────────────────────────────────────────────
SEED_ADMIN_PASSWORD=
SEED_USER_PASSWORD=

# ── TLS Let's Encrypt — Traefik uniquement ────────────────────────────────
#ACME_EMAIL=votre@email.com
