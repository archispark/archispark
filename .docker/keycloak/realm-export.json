{
  "realm": "archispark",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "attributes": {
    "_providerConfig.orgs.config.createAdminUser": "false"
  },
  "roles": {
    "realm": [
      {
        "name": "platform_admin",
        "description": "ArchiSpark platform administrator",
        "composite": false,
        "clientRole": false
      }
    ]
  },
  "clients": [
    {
      "clientId": "archispark-web",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": ["http://localhost:8000/*"],
      "webOrigins": ["http://localhost:8000"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "organizations",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-organization-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "organizations",
            "jsonType.label": "JSON",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "archispark-admin-web",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": ["http://localhost:8001/*"],
      "webOrigins": ["http://localhost:8001"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "organizations",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-organization-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "organizations",
            "jsonType.label": "JSON",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "archispark-control-api",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": true,
      "secret": "archispark-control-api-secret",
      "redirectUris": [],
      "webOrigins": []
    }
  ],
  "users": [
    {
      "id": "c8a1f6c0-0000-4000-8000-000000000001",
      "username": "admin",
      "enabled": true,
      "email": "admin@archispark.internal",
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "Archispark",
      "credentials": [{ "type": "password", "value": "admin", "temporary": false }],
      "realmRoles": ["platform_admin"]
    },
    {
      "id": "c8a1f6c0-0000-4000-8000-000000000002",
      "username": "user",
      "enabled": true,
      "email": "user@archispark.internal",
      "emailVerified": true,
      "firstName": "User",
      "lastName": "Archispark",
      "credentials": [{ "type": "password", "value": "user", "temporary": false }]
    },
    {
      "id": "c8a1f6c0-0000-4000-8000-000000000003",
      "username": "contrib",
      "enabled": true,
      "email": "contrib@archispark.internal",
      "emailVerified": true,
      "firstName": "Contrib",
      "lastName": "Archispark",
      "credentials": [{ "type": "password", "value": "contrib", "temporary": false }]
    },
    {
      "id": "c8a1f6c0-0000-4000-8000-000000000004",
      "username": "archi",
      "enabled": true,
      "email": "archi@archispark.internal",
      "emailVerified": true,
      "firstName": "Archi",
      "lastName": "Archispark",
      "credentials": [{ "type": "password", "value": "archi", "temporary": false }]
    },
    {
      "username": "service-account-archispark-control-api",
      "enabled": true,
      "serviceAccountClientId": "archispark-control-api",
      "clientRoles": {
        "realm-management": [
          "manage-users",
          "view-users",
          "query-users",
          "view-realm",
          "view-organizations",
          "manage-organizations"
        ]
      }
    }
  ]
}
